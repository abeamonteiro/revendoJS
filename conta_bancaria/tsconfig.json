{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",

    "rootDir": "./src",
    "outDir": "./dist",

    "moduleResolution": "node",

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}